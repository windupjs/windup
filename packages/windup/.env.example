# LLM API key — Google (default) or OpenAI
GOOGLE_GENERATIVE_AI_API_KEY=
# OPENAI_API_KEY=

# Optional: override the planner model for a single run
# (normally set in windup.config.ts; also: --llm provider[:model])
# LLM_MODEL=gemini-3.1-flash-lite

# Scenario credentials (exercises value_ref; public saucedemo demo values)
SAUCE_USER=standard_user
SAUCE_PASSWORD=secret_sauce

# Execution
HEADLESS=true
LOG_LEVEL=info

# Chromium path (needed in Docker; usually empty locally)
# CHROME_PATH=/usr/bin/chromium
