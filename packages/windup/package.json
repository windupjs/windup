{
  "name": "windupjs",
  "version": "0.1.0",
  "description": "Windup — testes E2E em linguagem natural: a LLM planeja uma vez, o replay roda sozinho",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "windup": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^3.6.0",
    "@clack/prompts": "^1.7.0",
    "@google/genai": "^2.11.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "c12": "^4.0.0-beta.5",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "jiti": "^2.7.0",
    "picomatch": "^4.0.5"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/picomatch": "^4.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
