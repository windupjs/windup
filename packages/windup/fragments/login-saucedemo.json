{
  "fragment_id": "login-saucedemo",
  "description": "Log in to saucedemo.com with the standard_user account (ends on the product list)",
  "actions": [
    {
      "id": "a1",
      "type": "fill",
      "target": {
        "selector": "#user-name",
        "description": "textbox: Username"
      },
      "value": "standard_user"
    },
    {
      "id": "a2",
      "type": "fill",
      "target": {
        "selector": "#password",
        "description": "textbox: Password"
      },
      "value": "secret_sauce"
    },
    {
      "id": "a3",
      "type": "click",
      "target": {
        "selector": "#login-button",
        "description": "button: Login"
      },
      "timeout_ms": 10000
    }
  ]
}
