{
  "fragment_id": "login-saucedemo",
  "description": "Login no saucedemo.com com o usuário standard_user (termina na lista de produtos)",
  "actions": [
    {
      "id": "a1",
      "type": "fill",
      "target": {
        "selector": "#user-name",
        "description": "textbox: Username"
      },
      "value": "standard_user"
    },
    {
      "id": "a2",
      "type": "fill",
      "target": {
        "selector": "#password",
        "description": "textbox: Password"
      },
      "value": "secret_sauce"
    },
    {
      "id": "a3",
      "type": "click",
      "target": {
        "selector": "#login-button",
        "description": "button: Login"
      },
      "timeout_ms": 10000
    }
  ]
}
